@page "/login"

<PageTitle>Studue Login</PageTitle>

<div class="login-page">
    <main class="login-shell">
        <section class="login-hero">
            <img src="/studue-logo.svg" alt="Studue logo" class="login-logo" />
            <h1>Shared assignment calendar for ZHAW students.</h1>
            <p>One person enters the assignment due date for a given module/class, and all others can see it.</p>
        </section>

        <section class="login-card">
            <img src="/studue-logo.svg" alt="Studue logo" class="login-logo-mobile" />

            <div class="login-copy">
                <h2>Use your student ID to see assignments.</h2>
                <p>Your schedule will be downloaded from stundenplan.zhaw.ch</p>
            </div>

            <form class="login-form" onsubmit="login(event)">
                <input
                    type="text"
                    id="studentId"
                    class="login-input"
                    placeholder="Enter student ID (eg. tomavant3)"
                    maxlength="8"
                    autocomplete="username"
                    required
                    />
                @if (message != null)
                {
                    <p style="color: #B23A48; margin: 0;">@message</p>
                }
                <button type="submit" class="login-button">Open my assignments</button>
            </form>
        </section>
    </main>
</div>

<script>
function login(e) {
    e.preventDefault();

    const studentId = document.getElementById("studentId").value;

    document.cookie = `student_id=${encodeURIComponent(studentId)}; path=/; SameSite=Lax; Max-Age=${60 * 60 * 24 * 365}`;

    window.location.href = "/";
}
</script>

@code
{
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string? message;

    protected override void OnInitialized()
    {
        if (HttpContext?.Request.Query.TryGetValue("message", out var m) is true)
        {
            message = m;
        }
    }
}
