@attribute [Authorize]
@attribute [StudentRequired]
@page "/admin/modules/{ModuleCode}/instances/{InstanceId:int}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@layout AdminLayout
@inject StudueContext StudueContext;
@inject NavigationManager Navigation;
@rendermode InteractiveServer

<section>
    <div>
        <div>
            <h2>Module instance</h2>
            <span>@_moduleInstance.Module.Name</span>
            <span>Section identifier: @_moduleInstance.LessionsId</span>
        </div>

        <div>
            <a href="/admin/modules/@ModuleCode">Back to module</a>
        </div>
    </div>
</section>

<section>
    <div>
        <h3>Students</h3>

        <table>
            <thead>
            <th>StudentId</th>
            <th>Class</th>
            </thead>
            <tbody>
            @foreach (var student in _moduleInstance.Students)
            {
                <tr>
                    <td>@student.StudentId</td>
                    <td>@student.Class</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div>
        <h3>Assignments</h3>

        <table>
            <thead>
            <th>Title</th>
            <th>DueDate</th>
            <th>Deleted</th>
            </thead>
            <tbody>
            @foreach (var assignment in _moduleInstance.Assignements)
            {
                <tr>
                    <td>@assignment.Title</td>
                    <td>@assignment.DueDateTime</td>
                    <td>@assignment.IsDeleted</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>


@code {
    [Parameter] public string ModuleCode { get; set; } = null!;
    [Parameter] public int InstanceId { get; set; }

    private ModuleInstance _moduleInstance = null!;

    protected override async Task OnParametersSetAsync()
    {
        var m = await StudueContext.ModuleInstances.Where(x => x.Id == InstanceId)
            .Include(x => x.Students)
            .ThenInclude(x => x.CreatedAssignments)
            .Include(x => x.Assignements)
            .Include(x => x.Module)
            .FirstOrDefaultAsync();
        if (m is null)
            Navigation.NotFound();
        else
            _moduleInstance = m;
    }
}
