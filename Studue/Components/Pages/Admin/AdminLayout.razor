@inherits LayoutComponentBase

<div class="admin-layout">
    <main class="admin-shell">
        <header class="admin-header">
            <div class="admin-branding">
                <img src="/studue-mark.svg" alt="Studue logo" class="admin-brand-mark" />

                <div class="admin-brand-copy">
                    <span class="admin-eyebrow">Administration</span>
                    <h1>Studue admin</h1>
                </div>
            </div>

            <nav class="admin-nav" aria-label="Admin sections">
                <NavLink class="admin-nav-link" href="/admin" Match="NavLinkMatch.All">Overview</NavLink>
                <NavLink class="admin-nav-link" href="/admin/modules" Match="NavLinkMatch.Prefix">Modules</NavLink>
                <NavLink class="admin-nav-link" href="/admin/students" Match="NavLinkMatch.Prefix">Students</NavLink>
                <NavLink class="admin-nav-link" href="/admin/editLog" Match="NavLinkMatch.Prefix">Edit Log</NavLink>
                <NavLink class="admin-nav-link" href="/admin/incidents" Match="NavLinkMatch.Prefix">Incidents</NavLink>
            </nav>
        </header>

        <section class="admin-content">
            @Body
        </section>
    </main>
</div>
